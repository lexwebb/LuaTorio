{
  "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.json",
      "!**/dist",
      "!**/node_modules",
      "!**/coverage",
      "!mcp-config.json"
    ]
  }
}
