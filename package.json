{
  "name": "luatorio",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome check --write .",
    "dev:web": "pnpm --filter @luatorio/web dev",
    "build:web": "pnpm --filter @luatorio/core build && pnpm --filter @luatorio/web build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
